# Shopify app credentials (filled by `shopify app dev` on first run)
SHOPIFY_API_KEY=
SHOPIFY_API_SECRET=
SHOPIFY_APP_URL=
SCOPES=read_customers

# Supabase Postgres
# Pooled connection for the app runtime (PgBouncer, port 6543):
DATABASE_URL="postgresql://postgres.<project-ref>:<password>@aws-<region>.pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1"
# Direct connection for Prisma migrations (port 5432):
DIRECT_URL="postgresql://postgres.<project-ref>:<password>@aws-<region>.pooler.supabase.com:5432/postgres"

# Shared bearer token for the direct-API endpoint (/api/newsletter).
# Generate with: openssl rand -hex 32
INGEST_API_TOKEN=
